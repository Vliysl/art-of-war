--!nocheck
-- AdjacencyGenerator (DEV TOOL, run in play mode after province_id is stamped).
--
-- Produces the baked Data/ProvinceAdjacency and Data/SeaZones tables from the live
-- map geometry. NOT loaded at boot (it's a Dev module, no register()); run it via the
-- Studio MCP in a play session, capture the returned module sources, and commit them.
--
--   local gen = require(game.ServerScriptService.ArtOfWar.Dev.AdjacencyGenerator)
--   local out = gen.generate()           -- { provinceAdjacencySource, seaZonesSource, stats }
--   return out.provinceAdjacencySource .. "\n===SEAZONES===\n" .. out.seaZonesSource
--
--   local sea = gen.generateSea()        -- { seaTileAdjacencySource, stats }  (C9 tile-level
--   return sea.seaTileAdjacencySource    --   bake; standalone so ProvinceAdjacency is NOT re-baked)
--
-- Land<->land adjacency = precise mesh overlap (inflate a temp proxy clone, then
-- workspace:GetPartsInPart, real collision geometry). Sea = a wrap-aware water grid:
-- each cell center is raycast down; no province under it = open water, classified by
-- WaterBodies (named) or an "open_sea" catch-all. Orthogonally-adjacent cells give
-- shore edges (land<->zone), sea<->sea edges, the coastal flag, and zone centroids.
-- The C9 sea pass (generateSea) bakes tile-level Data/SeaTileAdjacency separately:
-- a finer sea-bounded grid raycast against inflated Sea-part proxies yields sea<->sea
-- and sea<->province shore edges per TILE (the zone bake above stays untouched).

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = workspace

local AdjacencyGenerator = {}

-- Province meshes are authored flush (CollisionFidelity=Default), so a RAW
-- GetPartsInPart on the original part returns true bordering neighbors with no
-- inflation. Only provinces that end the raw pass with 0 neighbors are retried
-- with an inflated proxy (rescue pass) to bridge hairline gaps.
local DEFAULT_RESCUE_MARGIN = 14
local DEFAULT_CELL = 48 -- water-grid cell size in studs

-- C9 sea pass (tile-level Data/SeaTileAdjacency). The zone grid above is unusable for
-- it: its bounds derive from PROVINCE extents (sea tiles beyond land min/max Z would
-- never be sampled) and 48-stud cells are comparable to the average sea tile (~37
-- studs), so small strait tiles (Gibraltar/Bosphorus) fall between cell centers.
-- 8 studs divides MapWidth (2048) exactly -> the east-seam wrap column is
-- geometrically exact (no fractional last column like the floor'd zone grid).
local DEFAULT_SEA_CELL = 8
local SEA_PROXY_HEIGHT = 0.5 -- sea meshes are Size.Y = 0; downward raycasts need thickness
local SEA_RESCUE_MARGINS = { 6, 16, 32 } -- XZ inflation ladder for strait tiles the grid missed
local EXPECTED_SEA_TILES = 633

local function getProvincesFolder()
	local map = Workspace:FindFirstChild("ArtOfWarMap")
	return map and map:FindFirstChild("Provinces")
end

local function getSeaFolder()
	local map = Workspace:FindFirstChild("ArtOfWarMap")
	return map and map:FindFirstChild("Sea")
end

local function slug(name)
	local s = string.lower(name or "")
	s = s:gsub("[^%a%d]+", "_"):gsub("^_+", ""):gsub("_+$", "")
	if s == "" then
		s = "zone"
	end
	return s
end

-- ---- serialization (deterministic, sorted, valid Lua source) ----
local function serializeNumberArray(arr)
	table.sort(arr)
	local parts = {}
	for _, v in ipairs(arr) do
		parts[#parts + 1] = tostring(v)
	end
	return "{" .. table.concat(parts, ",") .. "}"
end

local function serializeStringArray(arr)
	table.sort(arr)
	local parts = {}
	for _, v in ipairs(arr) do
		parts[#parts + 1] = string.format("%q", v)
	end
	return "{" .. table.concat(parts, ",") .. "}"
end

local function buildProvinceAdjacencySource(provinces)
	-- provinces: sorted list of { id, land={}, coastal=bool, shore={} }
	local lines = {
		"-- BAKED true-geometric province adjacency. Generated by Dev/AdjacencyGenerator.",
		"-- Shape: [id] = { land = {ids}, coastal = bool, shore = {zoneKeys} }. DO NOT hand-edit.",
		"return {",
	}
	for _, p in ipairs(provinces) do
		lines[#lines + 1] = string.format(
			"\t[%d] = { land = %s, coastal = %s, shore = %s },",
			p.id,
			serializeNumberArray(p.land),
			tostring(p.coastal == true),
			serializeStringArray(p.shore)
		)
	end
	lines[#lines + 1] = "}"
	return table.concat(lines, "\n") .. "\n"
end

local function buildSeaZonesSource(zones)
	-- zones: sorted list of { key, name, kind, x, z, seaNeighbors={}, coastalProvinces={} }
	local lines = {
		"-- BAKED sea-zone graph. Generated by Dev/AdjacencyGenerator. DO NOT hand-edit.",
		"return {",
	}
	for _, z in ipairs(zones) do
		lines[#lines + 1] = string.format(
			"\t[%q] = { name = %q, kind = %q, pos = { x = %.1f, z = %.1f }, seaNeighbors = %s, coastalProvinces = %s },",
			z.key,
			z.name,
			z.kind,
			z.x,
			z.z,
			serializeStringArray(z.seaNeighbors),
			serializeNumberArray(z.coastalProvinces)
		)
	end
	lines[#lines + 1] = "}"
	return table.concat(lines, "\n") .. "\n"
end

local function buildSeaTileAdjacencySource(tiles)
	-- tiles: sorted list of { n, sea={partNumbers}, shore={provinceIds}, x, z }.
	-- Header mirrors the committed placeholder so a bake commit keeps the file docs.
	local lines = {
		"-- BAKED tile-level sea adjacency (C9 sea transport). Generated by Dev/AdjacencyGenerator's",
		"-- sea pass (run in Studio play mode); an empty table means no bake has run yet -- every sea",
		'-- consumer (AdjacencyGraph load, SeaNodes.nearestNode, ship rendering) degrades to "no sea".',
		"-- Shape: [partNumber] = { sea = { partNumber... }, shore = { provinceId... }, x = X, z = Z }",
		"-- (node ids in the movement graph are the NEGATED part numbers; see Shared/SeaNodes).",
		"-- NOTE: distinct from Data/SeaZones (the zone-level named-seas bake used by the dormant",
		"-- fleet system) -- do not confuse the two. DO NOT hand-edit.",
		"return {",
	}
	for _, t in ipairs(tiles) do
		lines[#lines + 1] = string.format(
			"\t[%d] = { sea = %s, shore = %s, x = %.1f, z = %.1f },",
			t.n,
			serializeNumberArray(t.sea),
			serializeNumberArray(t.shore),
			t.x,
			t.z
		)
	end
	lines[#lines + 1] = "}"
	return table.concat(lines, "\n") .. "\n"
end

-- Wait until provinces are FULLY stamped. Bootstrap stamps in waves and a
-- self-heal loop fills throttled mappings every ~6s for up to ~60s, so we only
-- treat the count as settled after it stops growing for ~15s (rides past the
-- self-heal bursts) -- not on the first transient plateau.
local function waitForStamp(folder, timeoutSec)
	local deadline = os.clock() + (timeoutSec or 90)
	local maxCount = 0
	local stablePolls = 0
	while os.clock() < deadline do
		local count = 0
		for _, part in folder:GetChildren() do
			if part:IsA("BasePart") and part:GetAttribute("province_id") then
				count += 1
			end
		end
		if count > maxCount then
			maxCount = count
			stablePolls = 0
		else
			stablePolls += 1
		end
		if maxCount > 2000 and stablePolls >= 5 then
			return maxCount
		end
		task.wait(3)
	end
	return maxCount
end

function AdjacencyGenerator.generate(opts)
	opts = opts or {}
	local cell = opts.cellSize or DEFAULT_CELL

	local folder = getProvincesFolder()
	assert(folder, "AdjacencyGenerator: ArtOfWarMap.Provinces not found")
	local stampedCount = waitForStamp(folder, opts.stampTimeout or 90)

	-- ---- Phase 1: index stamped provinces, positions, bounds, authored coastal ----
	local partById = {}
	local authoredCoastal = {}
	local minX, maxX, minZ, maxZ = math.huge, -math.huge, math.huge, -math.huge
	for _, part in folder:GetChildren() do
		if part:IsA("BasePart") then
			local pid = part:GetAttribute("province_id")
			if pid then
				partById[pid] = part
				authoredCoastal[pid] = part:GetAttribute("coastal") == true
				local px, pz = part.Position.X, part.Position.Z
				local hx, hz = part.Size.X * 0.5, part.Size.Z * 0.5
				if px - hx < minX then
					minX = px - hx
				end
				if px + hx > maxX then
					maxX = px + hx
				end
				if pz - hz < minZ then
					minZ = pz - hz
				end
				if pz + hz > maxZ then
					maxZ = pz + hz
				end
			end
		end
	end

	-- ---- Phase 2: land<->land via mesh overlap (raw; flush meshes) ----
	local overlap = OverlapParams.new()
	overlap.FilterType = Enum.RaycastFilterType.Include
	overlap.FilterDescendantsInstances = { folder }
	overlap.MaxParts = 0

	local landSet = {} -- [pid] = { [neighborPid] = true }
	local function addLand(a, b)
		local s = landSet[a]
		if not s then
			s = {}
			landSet[a] = s
		end
		s[b] = true
	end
	local function collectFrom(queryPart, pid)
		for _, hit in Workspace:GetPartsInPart(queryPart, overlap) do
			local hid = hit:GetAttribute("province_id")
			if hid and hid ~= pid then
				addLand(pid, hid)
				addLand(hid, pid)
			end
		end
	end

	-- Raw pass: flush meshes return true borderers with no inflation.
	-- (The gap-rescue runs LATER, after coastal frontage is known, so true islands
	-- aren't wrongly bridged across water.)
	for pid, part in partById do
		landSet[pid] = landSet[pid] or {}
		collectFrom(part, pid)
	end

	-- ---- Phase 3: water grid ----
	local rcParams = RaycastParams.new()
	rcParams.FilterType = Enum.RaycastFilterType.Include
	rcParams.FilterDescendantsInstances = { folder }

	local WaterBodies = require(ReplicatedStorage.ArtOfWar.Modules.WaterBodies)

	local cols = math.max(1, math.floor((maxX - minX) / cell))
	local rows = math.max(1, math.floor((maxZ - minZ) / cell))

	-- cellLand[c][r] = pid (land) ; cellZone[c][r] = zoneKey (water). nil = neither (no raycast hit but not classified)
	local cellLand = {}
	local cellZone = {}
	local zoneName = {} -- key -> display name
	local zoneKind = {} -- key -> kind
	local zoneCellCount = {}
	local zoneSumX, zoneSumZ = {}, {}

	local function recordZoneCell(key, name, kind, x, z)
		if not zoneName[key] then
			zoneName[key] = name
			zoneKind[key] = kind
			zoneCellCount[key] = 0
			zoneSumX[key] = 0
			zoneSumZ[key] = 0
		end
		zoneCellCount[key] += 1
		zoneSumX[key] += x
		zoneSumZ[key] += z
	end

	for c = 0, cols do
		cellLand[c] = {}
		cellZone[c] = {}
		local x = minX + c * cell + cell * 0.5
		for r = 0, rows do
			local z = minZ + r * cell + cell * 0.5
			local origin = Vector3.new(x, 2000, z)
			local res = Workspace:Raycast(origin, Vector3.new(0, -4000, 0), rcParams)
			local hit = res and res.Instance
			local hitPid = hit and hit:GetAttribute("province_id")
			if hit then
				-- Any Provinces-folder hit is LAND. A part still lacking a
				-- province_id (throttled stamp) is "unknown land": it blocks water
				-- but generates no province shore edge -- never misread as sea.
				cellLand[c][r] = hitPid or true
			else
				local name, kind = WaterBodies.getWaterBodyAt(x, z)
				local key, dispName, dispKind
				if name then
					key, dispName, dispKind = slug(name), name, string.lower(kind or "sea")
				else
					key, dispName, dispKind = "open_sea", "Open Sea", "open_sea"
				end
				cellZone[c][r] = key
				recordZoneCell(key, dispName, dispKind, x, z)
			end
		end
	end

	-- ---- Phase 4: shore (land<->zone), sea<->sea, coastal, from orthogonal cell adjacency ----
	local provinceShore = {} -- [pid] = { [zoneKey] = true }
	local zoneProvinces = {} -- [zoneKey] = { [pid] = true }
	local zoneNeighbors = {} -- [zoneKey] = { [otherKey] = true }
	local function addShore(pid, key)
		local s = provinceShore[pid]
		if not s then
			s = {}
			provinceShore[pid] = s
		end
		s[key] = true
		local zp = zoneProvinces[key]
		if not zp then
			zp = {}
			zoneProvinces[key] = zp
		end
		zp[pid] = true
	end
	local function addZoneEdge(a, b)
		if a == b then
			return
		end
		local s = zoneNeighbors[a]
		if not s then
			s = {}
			zoneNeighbors[a] = s
		end
		s[b] = true
		local s2 = zoneNeighbors[b]
		if not s2 then
			s2 = {}
			zoneNeighbors[b] = s2
		end
		s2[a] = true
	end

	local function classify(c, r)
		-- returns ("land", pid) | ("landUnknown", nil) | ("water", key) | nil
		local landVal = cellLand[c] and cellLand[c][r]
		if landVal == true then
			return "landUnknown", nil
		end
		if landVal then
			return "land", landVal
		end
		if cellZone[c] and cellZone[c][r] then
			return "water", cellZone[c][r]
		end
		return nil, nil
	end

	for c = 0, cols do
		for r = 0, rows do
			local kindA, valA = classify(c, r)
			if kindA then
				-- east neighbor with horizontal wrap (seam connects last col to col 0)
				local ec = (c == cols) and 0 or (c + 1)
				local neighborsRC = { { ec, r }, { c, math.min(r + 1, rows) } }
				for _, rc in ipairs(neighborsRC) do
					local kindB, valB = classify(rc[1], rc[2])
					if kindB then
						if kindA == "land" and kindB == "water" then
							addShore(valA, valB)
						elseif kindA == "water" and kindB == "land" then
							addShore(valB, valA)
						elseif kindA == "water" and kindB == "water" and valA ~= valB then
							addZoneEdge(valA, valB)
						end
					end
				end
			end
		end
	end

	-- ---- Phase 4.6: coastal rescue for thin provinces the coarse cell grid missed ----
	-- A province thinner than a grid cell in either dimension can have NO cell center land on
	-- it, so it never records a shore edge even when it borders sea (e.g. Puerto Rico, 16x4).
	-- For each shore-less thin province, sample a ring just outside its bounds; a sample that
	-- hits no province part is water -> classify its zone and add the shore edge. Runs BEFORE
	-- the gap-rescue so a rescued coastal island is no longer "stranded" and never land-bridged.
	local coastalRescued = 0
	for pid, part in partById do
		if not (provinceShore[pid] and next(provinceShore[pid])) and math.min(part.Size.X, part.Size.Z) < cell then
			local px, pz = part.Position.X, part.Position.Z
			local hx, hz = part.Size.X * 0.5, part.Size.Z * 0.5
			local sx = math.max(4, part.Size.X / 4)
			local sz = math.max(4, part.Size.Z / 4)
			local found = false
			for _, margin in ipairs({ 6, 16 }) do
				local pts = {}
				for dx = -hx, hx, sx do
					pts[#pts + 1] = Vector3.new(px + dx, 2000, pz - hz - margin)
					pts[#pts + 1] = Vector3.new(px + dx, 2000, pz + hz + margin)
				end
				for dz = -hz, hz, sz do
					pts[#pts + 1] = Vector3.new(px - hx - margin, 2000, pz + dz)
					pts[#pts + 1] = Vector3.new(px + hx + margin, 2000, pz + dz)
				end
				for _, o in ipairs(pts) do
					if not Workspace:Raycast(o, Vector3.new(0, -4000, 0), rcParams) then
						local name, kind = WaterBodies.getWaterBodyAt(o.X, o.Z)
						local key = name and slug(name) or "open_sea"
						if not zoneName[key] then
							recordZoneCell(
								key,
								name or "Open Sea",
								name and string.lower(kind or "sea") or "open_sea",
								o.X,
								o.Z
							)
						end
						addShore(pid, key)
						found = true
					end
				end
				if found then
					break
				end
			end
			if found then
				coastalRescued += 1
			end
		end
	end
	print(string.format("[AdjGen] coastal rescue: %d thin shore-less provinces recovered as coastal", coastalRescued))

	-- ---- Phase 4.4: gap-tolerant land borders (direct geometry, water-guarded) ----
	-- Phase 2 records a land edge only on true mesh contact (margin 0), so two provinces split by
	-- a sub-stud tessellation gap miss their shared border -- leaving some provinces with an empty
	-- land set even though they are walkable. Re-query each land-LESS province with a small
	-- inflation and add same-Y neighbors, GUARDED so we never bridge across water: the midpoint of
	-- the two centroids must sit over land (a Provinces raycast hits). True islands stay land-less
	-- (their nearby land is across water -> midpoint over water -> rejected).
	local GAP_MARGIN = opts.landGapMargin or 2
	do
		local gapFolder = Instance.new("Folder")
		gapFolder.Name = "__AdjGenLandGap"
		gapFolder.Parent = Workspace
		local addedEdges, fixedProvs = 0, 0
		for pid, part in partById do
			if next(landSet[pid]) == nil then
				local ok, clone = pcall(function()
					return part:Clone()
				end)
				if ok and clone then
					clone:ClearAllChildren()
					clone.Anchored = true
					clone.CanCollide = false
					clone.CanQuery = true
					clone.Size = part.Size + Vector3.new(GAP_MARGIN, 0, GAP_MARGIN)
					clone.CFrame = part.CFrame
					clone.Parent = gapFolder
					local gained = false
					for _, hit in Workspace:GetPartsInPart(clone, overlap) do
						local hid = hit:GetAttribute("province_id")
						if hid and hid ~= pid and not landSet[pid][hid] then
							local other = partById[hid]
							if other and math.abs(other.Position.Y - part.Position.Y) < 3 then
								local mx = (part.Position.X + other.Position.X) * 0.5
								local mz = (part.Position.Z + other.Position.Z) * 0.5
								local midHit =
									Workspace:Raycast(Vector3.new(mx, 2000, mz), Vector3.new(0, -4000, 0), rcParams)
								if midHit then
									addLand(pid, hid)
									addLand(hid, pid)
									addedEdges += 2
									gained = true
								end
							end
						end
					end
					clone:Destroy()
					if gained then
						fixedProvs += 1
					end
				end
			end
		end
		gapFolder:Destroy()
		print(
			string.format(
				"[AdjGen] gap-tolerant land: +%d directed edges, %d land-less provinces gained neighbors (margin %d, water-guarded)",
				addedEdges,
				fixedProvs,
				GAP_MARGIN
			)
		)
	end

	-- ---- Phase 4.5: gap-rescue for stranded provinces ----
	-- A province that is NON-coastal AND has 0 land neighbors is unreachable. It's
	-- separated from its true neighbors by a gap wider than the raw overlap caught
	-- (never a real island -- those are coastal). Escalate an inflated proxy until a
	-- land neighbor appears. Only these few provinces get inflated, so over-connection
	-- can't reintroduce hopping for the rest of the map.
	local rescueMargins = opts.rescueMargins or { 20, 45, 90, 160 }
	local rescueTried, rescued = 0, 0
	local stillIsolated = {}
	do
		local proxyFolder = Instance.new("Folder")
		proxyFolder.Name = "__AdjGenProxies"
		proxyFolder.Parent = Workspace
		for pid, part in partById do
			local stranded = next(landSet[pid]) == nil
				and (provinceShore[pid] == nil or next(provinceShore[pid]) == nil)
			if stranded then
				rescueTried += 1
				for _, m in ipairs(rescueMargins) do
					local ok, clone = pcall(function()
						return part:Clone()
					end)
					if ok and clone then
						clone:ClearAllChildren()
						clone.Anchored = true
						clone.CanCollide = false
						clone.CanQuery = true
						clone.Size = part.Size + Vector3.new(m, 0, m)
						clone.CFrame = part.CFrame
						clone.Parent = proxyFolder
						collectFrom(clone, pid)
						clone:Destroy()
					end
					if next(landSet[pid]) ~= nil then
						break
					end
				end
				if next(landSet[pid]) ~= nil then
					rescued += 1
				else
					stillIsolated[#stillIsolated + 1] = pid
				end
			end
		end
		proxyFolder:Destroy()
	end

	-- Final guarantee: no province is ever fully unreachable. Connect any province
	-- still isolated to its nearest neighbour by centroid. Logged so the map author
	-- can fix the underlying geometry; in practice these are a handful of tiny
	-- island/void provinces.
	local forced = 0
	for _, pid in ipairs(stillIsolated) do
		local pa = partById[pid].Position
		local bestId, bestD = nil, math.huge
		for otherId, otherPart in partById do
			if otherId ~= pid then
				local d = (otherPart.Position - pa).Magnitude
				if d < bestD then
					bestD = d
					bestId = otherId
				end
			end
		end
		if bestId then
			addLand(pid, bestId)
			addLand(bestId, pid)
			forced += 1
		end
	end
	print(
		string.format(
			"[AdjGen] gap-rescue: %d stranded, %d bridged, %d forced to nearest (ids: %s)",
			rescueTried,
			rescued,
			forced,
			table.concat(stillIsolated, ",")
		)
	)

	-- ---- Phase 5: assemble outputs ----
	local provinces = {}
	local provIds = {}
	for pid in partById do
		provIds[#provIds + 1] = pid
	end
	table.sort(provIds)

	local histogram = {}
	local coastalCount = 0
	local islandSuspicious = {} -- non-coastal with 0 land neighbors
	local reconAuthoredOnly, reconGeomOnly = {}, {}

	for _, pid in ipairs(provIds) do
		local land = {}
		for n in (landSet[pid] or {}) do
			land[#land + 1] = n
		end
		local shore = {}
		for key in (provinceShore[pid] or {}) do
			shore[#shore + 1] = key
		end
		local coastal = #shore > 0
		if coastal then
			coastalCount += 1
		end

		provinces[#provinces + 1] = { id = pid, land = land, coastal = coastal, shore = shore }

		local deg = #land
		histogram[deg] = (histogram[deg] or 0) + 1
		if not coastal and deg == 0 then
			islandSuspicious[#islandSuspicious + 1] = pid
		end
		if authoredCoastal[pid] and not coastal then
			reconAuthoredOnly[#reconAuthoredOnly + 1] = pid
		end
		if coastal and not authoredCoastal[pid] then
			reconGeomOnly[#reconGeomOnly + 1] = pid
		end
	end

	local zones = {}
	local zoneKeys = {}
	for key in zoneName do
		zoneKeys[#zoneKeys + 1] = key
	end
	table.sort(zoneKeys)
	for _, key in ipairs(zoneKeys) do
		local n = {}
		for ok in (zoneNeighbors[key] or {}) do
			n[#n + 1] = ok
		end
		local cp = {}
		for pid in (zoneProvinces[key] or {}) do
			cp[#cp + 1] = pid
		end
		local count = zoneCellCount[key] or 1
		zones[#zones + 1] = {
			key = key,
			name = zoneName[key],
			kind = zoneKind[key],
			x = zoneSumX[key] / count,
			z = zoneSumZ[key] / count,
			seaNeighbors = n,
			coastalProvinces = cp,
		}
	end

	-- ---- diagnostics ----
	print(
		string.format(
			"[AdjGen] stamped=%d indexed=%d  grid=%dx%d cell=%d",
			stampedCount,
			#provIds,
			cols + 1,
			rows + 1,
			cell
		)
	)
	local degs = {}
	for d in histogram do
		degs[#degs + 1] = d
	end
	table.sort(degs)
	local hbits = {}
	local totalEdges = 0
	for _, d in ipairs(degs) do
		hbits[#hbits + 1] = string.format("%d:%d", d, histogram[d])
		totalEdges += d * histogram[d]
	end
	print("[AdjGen] land-neighbor histogram (degree:count) -> " .. table.concat(hbits, "  "))
	print(
		string.format("[AdjGen] total directed land edges=%d  coastal=%d  zones=%d", totalEdges, coastalCount, #zones)
	)
	print(
		string.format(
			"[AdjGen] coastal reconcile: authored-not-geom=%d  geom-not-authored=%d  suspicious-landlocked-islands=%d",
			#reconAuthoredOnly,
			#reconGeomOnly,
			#islandSuspicious
		)
	)
	if #islandSuspicious > 0 then
		local sample = {}
		for i = 1, math.min(#islandSuspicious, 20) do
			sample[i] = islandSuspicious[i]
		end
		print("[AdjGen] suspicious (non-coastal, 0 land neighbors) sample ids: " .. table.concat(sample, ", "))
	end

	return {
		provinceAdjacencySource = buildProvinceAdjacencySource(provinces),
		seaZonesSource = buildSeaZonesSource(zones),
		stats = {
			stampedCount = stampedCount,
			indexed = #provIds,
			totalEdges = totalEdges,
			coastalCount = coastalCount,
			zones = #zones,
			suspicious = #islandSuspicious,
		},
	}
end

-- ---- C9 sea pass: tile-level Data/SeaTileAdjacency bake ----
-- Standalone on purpose: the C9 bake must NOT regenerate ProvinceAdjacency (already
-- committed; a re-bake would churn unrelated diffs). Design (audit-mandated):
--   * bounds come from the SEA parts' own extents, not province extents;
--   * a fine grid (DEFAULT_SEA_CELL, divides MapWidth) chosen over per-tile seeded
--     sampling because grid-cell adjacency is what yields BOTH sea<->sea and
--     sea<->shore edges in one pass AND wraps the east seam for the Pacific crossing
--     -- per-tile sampling would need a second geometric pass for edges and can't
--     see across the seam at all; tiles thinner than a cell are caught by an exact
--     GetPartsInPart overlap rescue afterwards;
--   * sea meshes are Size.Y = 0, so raycasts target inflated proxy clones (same
--     technique as the land gap-rescue above);
--   * land wins: a cell records a sea tile only when NO province part is hit.
function AdjacencyGenerator.generateSea(opts)
	opts = opts or {}
	local cell = opts.seaCellSize or DEFAULT_SEA_CELL

	local WorldConstants = require(ReplicatedStorage.ArtOfWar.Shared.WorldConstants)
	local mapWidth = WorldConstants.MapWidth

	local provFolder = getProvincesFolder()
	assert(provFolder, "AdjacencyGenerator: ArtOfWarMap.Provinces not found")
	local seaFolder = getSeaFolder()
	assert(seaFolder, "AdjacencyGenerator: ArtOfWarMap.Sea not found")
	-- Shore edges are keyed by province_id, so the sea pass needs the same
	-- fully-stamped guarantee as the land pass.
	waitForStamp(provFolder, opts.stampTimeout or 90)

	-- ---- Sea phase 1: index sea parts (sea_<n>_<Name>) + sea-derived bounds ----
	local partByNumber = {}
	local duplicates = 0
	local minX, maxX, minZ, maxZ = math.huge, -math.huge, math.huge, -math.huge
	for _, part in seaFolder:GetChildren() do
		if part:IsA("BasePart") then
			local n = tonumber(string.match(part.Name, "^sea_(%d+)"))
			if n then
				if partByNumber[n] then
					duplicates += 1
				else
					partByNumber[n] = part
					local px, pz = part.Position.X, part.Position.Z
					local hx, hz = part.Size.X * 0.5, part.Size.Z * 0.5
					if px - hx < minX then
						minX = px - hx
					end
					if px + hx > maxX then
						maxX = px + hx
					end
					if pz - hz < minZ then
						minZ = pz - hz
					end
					if pz + hz > maxZ then
						maxZ = pz + hz
					end
				end
			end
		end
	end
	local seaNumbers = {}
	for n in partByNumber do
		seaNumbers[#seaNumbers + 1] = n
	end
	table.sort(seaNumbers)
	assert(#seaNumbers > 0, "AdjacencyGenerator: no sea_<n>_* parts under ArtOfWarMap.Sea")
	if maxX - minX > mapWidth + 1 then
		warn(
			string.format(
				"[AdjGen:sea] sea X extent %.0f exceeds MapWidth %d -- wrap-clone parts leaked into the main Sea folder?",
				maxX - minX,
				mapWidth
			)
		)
	end

	-- Stamped province ids, for the id-collision diagnostic (non-fatal: sea node ids
	-- are the NEGATED part numbers, so the graph keyspaces can never collide).
	local stampedPid = {}
	for _, part in provFolder:GetChildren() do
		if part:IsA("BasePart") then
			local pid = part:GetAttribute("province_id")
			if pid then
				stampedPid[pid] = true
			end
		end
	end
	local collisions = {}
	for _, n in ipairs(seaNumbers) do
		if stampedPid[n] then
			collisions[#collisions + 1] = n
		end
	end

	-- ---- Sea phase 2: inflated proxies (Size.Y = 0 meshes are unreliable raycast targets) ----
	local proxyFolder = Instance.new("Folder")
	proxyFolder.Name = "__AdjGenSeaProxies"
	proxyFolder.Parent = Workspace
	local proxyByNumber = {}
	for _, n in ipairs(seaNumbers) do
		local part = partByNumber[n]
		local ok, clone = pcall(function()
			return part:Clone()
		end)
		if ok and clone then
			clone:ClearAllChildren()
			clone.Anchored = true
			clone.CanCollide = false
			clone.CanQuery = true
			clone.Size = Vector3.new(part.Size.X, SEA_PROXY_HEIGHT, part.Size.Z)
			clone.CFrame = part.CFrame
			clone:SetAttribute("sea_part_number", n)
			clone.Parent = proxyFolder
			proxyByNumber[n] = clone
		end
	end

	-- ---- Sea phase 3: fine grid over the sea extents ----
	-- X spans exactly one map period anchored at the sea min-X: the world repeats
	-- every MapWidth, so column cols-1 and column 0 are one cell apart across the
	-- seam wherever the anchor falls (cell divides MapWidth -> the wrap is exact,
	-- which is why the loop runs 0..cols-1 with a modulo east neighbor, unlike the
	-- zone grid's inclusive 0..cols). Z has no wrap; pad so coastal land just
	-- beyond the sea extents still gets classified for shore edges.
	local cols = math.max(1, math.floor(mapWidth / cell + 0.5))
	local pad = cell * 2
	local gridMinZ = minZ - pad
	local rows = math.max(1, math.ceil((maxZ + pad - gridMinZ) / cell))

	local landRc = RaycastParams.new()
	landRc.FilterType = Enum.RaycastFilterType.Include
	landRc.FilterDescendantsInstances = { provFolder }
	local seaRc = RaycastParams.new()
	seaRc.FilterType = Enum.RaycastFilterType.Include
	seaRc.FilterDescendantsInstances = { proxyFolder }

	-- cellSea[c][r] = sea part number. Land wins: a cell over any province stays nil, so open
	-- water is never misread. (cellLand is no longer stored -- shore is computed by direct mesh
	-- overlap in Sea phase 4.6, not from these cells; the grid now only yields sea<->sea edges.)
	local cellSea = {}
	for c = 0, cols - 1 do
		cellSea[c] = {}
		local x = minX + c * cell + cell * 0.5
		for r = 0, rows do
			local z = gridMinZ + r * cell + cell * 0.5
			local origin = Vector3.new(x, 2000, z)
			if not Workspace:Raycast(origin, Vector3.new(0, -4000, 0), landRc) then
				local seaRes = Workspace:Raycast(origin, Vector3.new(0, -4000, 0), seaRc)
				local n = seaRes and seaRes.Instance:GetAttribute("sea_part_number")
				if n then
					cellSea[c][r] = n
				end
			end
		end
		-- This grid is ~36x denser than the zone grid; yield periodically so the
		-- play session doesn't hitch through one giant raycast burst.
		if c % 32 == 31 then
			task.wait()
		end
	end

	-- ---- Sea phase 4: orthogonal cell adjacency -> sea<->sea + sea<->shore edges ----
	local seaSet = {} -- [n] = { [otherN] = true }
	local shoreSet = {} -- [n] = { [pid] = true }
	local seaEdgeCount, shoreEdgeCount = 0, 0
	local seamPairs = {} -- unique sea<->sea pairs seen across the east wrap column
	local function addSeaEdge(a, b, atSeam)
		if a == b then
			return
		end
		local s = seaSet[a]
		if not s then
			s = {}
			seaSet[a] = s
		end
		if not s[b] then
			s[b] = true
			local s2 = seaSet[b]
			if not s2 then
				s2 = {}
				seaSet[b] = s2
			end
			s2[a] = true
			seaEdgeCount += 1
		end
		if atSeam then
			seamPairs[math.min(a, b) .. ":" .. math.max(a, b)] = true
		end
	end
	local function addShoreEdge(n, pid)
		local s = shoreSet[n]
		if not s then
			s = {}
			shoreSet[n] = s
		end
		if not s[pid] then
			s[pid] = true
			shoreEdgeCount += 1
		end
	end

	-- Sea<->sea adjacency from the grid (seam-aware: last column wraps to column 0). Shore
	-- (sea<->province) is NOT taken from the grid anymore -- it is computed by direct mesh overlap
	-- in Sea phase 4.6, which sees contained/overlapping/thin provinces the cells cannot.
	for c = 0, cols - 1 do
		for r = 0, rows do
			local seaA = cellSea[c][r]
			if seaA then
				-- east neighbor wraps: column cols-1 meets column 0 across the seam
				local ec = (c + 1) % cols
				local neighborsRC = { { ec, r, c == cols - 1 }, { c, math.min(r + 1, rows), false } }
				for _, rc in ipairs(neighborsRC) do
					local seaB = cellSea[rc[1]][rc[2]]
					if seaB then
						addSeaEdge(seaA, seaB, rc[3])
					end
				end
			end
		end
	end

	-- ---- Sea phase 4.5: exact-overlap rescue for tiles the grid missed ----
	-- Strait tiles can be thinner than one cell even at 8 studs; any tile that ends
	-- the grid pass with no edge at all gets an escalating inflated-proxy
	-- GetPartsInPart against the sea proxies + provinces (real contact geometry,
	-- same technique as the land gap-rescue).
	local seaOverlap = OverlapParams.new()
	seaOverlap.FilterType = Enum.RaycastFilterType.Include
	seaOverlap.FilterDescendantsInstances = { proxyFolder, provFolder }
	seaOverlap.MaxParts = 0
	local function hasAnyEdge(n)
		return (seaSet[n] and next(seaSet[n]) ~= nil) or (shoreSet[n] and next(shoreSet[n]) ~= nil)
	end
	local rescueTried, rescued = 0, 0
	for _, n in ipairs(seaNumbers) do
		if not hasAnyEdge(n) and proxyByNumber[n] then
			rescueTried += 1
			local proxy = proxyByNumber[n]
			for _, m in ipairs(SEA_RESCUE_MARGINS) do
				local ok, probe = pcall(function()
					return proxy:Clone()
				end)
				if ok and probe then
					probe:SetAttribute("sea_part_number", nil) -- probe must never read as tile n
					probe.Size = proxy.Size + Vector3.new(m, 0, m)
					probe.Parent = proxyFolder
					for _, hit in Workspace:GetPartsInPart(probe, seaOverlap) do
						local hitN = hit:GetAttribute("sea_part_number")
						local hitPid = hit:GetAttribute("province_id")
						if hitN and hitN ~= n then
							addSeaEdge(n, hitN, false)
						elseif hitPid then
							addShoreEdge(n, hitPid)
						end
					end
					probe:Destroy()
				end
				if hasAnyEdge(n) then
					break
				end
			end
			if hasAnyEdge(n) then
				rescued += 1
			end
		end
	end
	-- ---- Sea phase 4.6: direct-geometry shore (sea<->province) ----
	-- Shore edges come from real mesh overlap, NOT the cell grid: a province is on tile n's shore
	-- iff their footprints touch. This catches provinces that overlap or sit ENTIRELY INSIDE a
	-- tile's footprint (contained islands) and thin provinces the 8-stud grid never sampled -- the
	-- cases the old cell-adjacency shore missed. Each sea tile gets a tall, slightly inflated proxy
	-- queried against the real province meshes. No seam wrap here: a province and the sea it borders
	-- share an X, so no cross-seam pairing arises (that is purely a sea<->sea concern above).
	local shoreOP = OverlapParams.new()
	shoreOP.FilterType = Enum.RaycastFilterType.Include
	shoreOP.FilterDescendantsInstances = { provFolder }
	shoreOP.MaxParts = 0
	local SHORE_MARGIN = opts.shoreMargin or 2
	for _, n in ipairs(seaNumbers) do
		local base = proxyByNumber[n]
		if base then
			local q = base:Clone()
			q:ClearAllChildren()
			q.Anchored = true
			q.CanCollide = false
			q.CanQuery = true
			q:SetAttribute("sea_part_number", nil)
			q.Size = Vector3.new(base.Size.X + SHORE_MARGIN, 200, base.Size.Z + SHORE_MARGIN)
			q.CFrame = CFrame.new(base.Position.X, 0, base.Position.Z)
			q.Parent = proxyFolder
			for _, hit in Workspace:GetPartsInPart(q, shoreOP) do
				local pid = hit:GetAttribute("province_id")
				if pid then
					addShoreEdge(n, pid)
				end
			end
			q:Destroy()
		end
	end

	-- Coastal-coverage guarantee: every province the zone bake calls coastal must end with a shore
	-- edge (else it is unreachable by sea). The pass above catches all that touch a tile within
	-- SHORE_MARGIN; escalate any coastal province still shore-less (sea mesh inset from its coast)
	-- with a growing proxy until a sea tile is hit.
	local provWithShore = {}
	for _, sset in pairs(shoreSet) do
		for pid in pairs(sset) do
			provWithShore[pid] = true
		end
	end
	local coastalPA
	do
		local okPA, pa = pcall(function()
			return require(game:GetService("ServerScriptService").ArtOfWar.ServerData.ProvinceAdjacency)
		end)
		coastalPA = (okPA and type(pa) == "table") and pa or nil
	end
	local seaQueryOP = OverlapParams.new()
	seaQueryOP.FilterType = Enum.RaycastFilterType.Include
	seaQueryOP.FilterDescendantsInstances = { proxyFolder }
	seaQueryOP.MaxParts = 0
	local backstopped = 0
	for _, part in provFolder:GetChildren() do
		if part:IsA("BasePart") then
			local pid = part:GetAttribute("province_id")
			local isCoastal = pid ~= nil
				and coastalPA ~= nil
				and coastalPA[pid] ~= nil
				and coastalPA[pid].coastal == true
			if isCoastal and not provWithShore[pid] then
				for _, m in ipairs({ 8, 16, 28 }) do
					local ok, q = pcall(function()
						return part:Clone()
					end)
					if ok and q then
						q:ClearAllChildren()
						q.Anchored = true
						q.CanCollide = false
						q.CanQuery = true
						q.Size = Vector3.new(part.Size.X + m, 200, part.Size.Z + m)
						q.CFrame = CFrame.new(part.Position.X, 0, part.Position.Z)
						q.Parent = proxyFolder
						local found = false
						for _, hit in Workspace:GetPartsInPart(q, seaQueryOP) do
							local hn = hit:GetAttribute("sea_part_number")
							if hn then
								addShoreEdge(hn, pid)
								found = true
							end
						end
						q:Destroy()
						if found then
							provWithShore[pid] = true
							backstopped += 1
							break
						end
					end
				end
			end
		end
	end
	print(
		string.format(
			"[AdjGen:sea] direct shore: shore edges=%d; coastal backstop rescued %d",
			shoreEdgeCount,
			backstopped
		)
	)

	proxyFolder:Destroy()

	-- ---- Sea phase 5: assemble + diagnostics ----
	-- Connected components over sea<->sea edges only (lakes = small isolates).
	local componentOf = {}
	local components = {} -- { size, rep } ; rep = smallest member (seaNumbers is sorted)
	for _, n in ipairs(seaNumbers) do
		if not componentOf[n] then
			local queue = { n }
			componentOf[n] = n
			local size = 0
			while #queue > 0 do
				local cur = table.remove(queue)
				size += 1
				for other in (seaSet[cur] or {}) do
					if not componentOf[other] then
						componentOf[other] = n
						queue[#queue + 1] = other
					end
				end
			end
			components[#components + 1] = { size = size, rep = n }
		end
	end
	table.sort(components, function(a, b)
		if a.size ~= b.size then
			return a.size < b.size
		end
		return a.rep < b.rep
	end)

	local orphans = {}
	local tiles = {}
	for _, n in ipairs(seaNumbers) do
		if not hasAnyEdge(n) then
			orphans[#orphans + 1] = partByNumber[n].Name
		end
		local sea = {}
		for other in (seaSet[n] or {}) do
			sea[#sea + 1] = other
		end
		local shore = {}
		for pid in (shoreSet[n] or {}) do
			shore[#shore + 1] = pid
		end
		-- x/z = the part's own Position (SeaNodes.nearestNode click targeting).
		local pos = partByNumber[n].Position
		tiles[#tiles + 1] = { n = n, sea = sea, shore = shore, x = pos.X, z = pos.Z }
	end

	local seamEdges = 0
	for _ in seamPairs do
		seamEdges += 1
	end

	print(
		string.format(
			"[AdjGen:sea] tiles=%d (expected %d)  duplicate-numbered parts=%d  grid=%dx%d cell=%d",
			#seaNumbers,
			EXPECTED_SEA_TILES,
			duplicates,
			cols,
			rows + 1,
			cell
		)
	)
	if #seaNumbers ~= EXPECTED_SEA_TILES then
		warn(
			string.format(
				"[AdjGen:sea] tile count %d != expected %d -- check ArtOfWarMap.Sea naming",
				#seaNumbers,
				EXPECTED_SEA_TILES
			)
		)
	end
	print(
		string.format(
			"[AdjGen:sea] id collisions vs stamped province_ids=%d (non-fatal; sea node ids are negated)%s",
			#collisions,
			#collisions > 0 and (" -> " .. table.concat(collisions, ",")) or ""
		)
	)
	print(
		string.format(
			"[AdjGen:sea] edges: sea<->sea=%d  shore=%d  rescue: %d tried, %d bridged",
			seaEdgeCount,
			shoreEdgeCount,
			rescueTried,
			rescued
		)
	)
	local compBits = {}
	for i = 1, math.min(#components, 10) do
		local comp = components[i]
		compBits[#compBits + 1] = string.format("%s(%d)", partByNumber[comp.rep].Name, comp.size)
	end
	print(
		string.format(
			"[AdjGen:sea] connected components=%d; 10 smallest (rep tile, size): %s",
			#components,
			table.concat(compBits, "  ")
		)
	)
	if seamEdges > 0 then
		print(string.format("[AdjGen:sea] seam(+-MapHalfWidth) crossing sea edges=%d -- Pacific wrap OK", seamEdges))
	else
		warn("[AdjGen:sea] NO sea edge crosses the east seam -- Pacific wrap broken, check grid bounds/cell size")
	end
	if #orphans > 0 then
		warn(
			string.format(
				"[AdjGen:sea] STRAIT SANITY FAILED: %d tiles with NO sea/shore edge: %s",
				#orphans,
				table.concat(orphans, ", ")
			)
		)
	else
		print("[AdjGen:sea] strait sanity OK: every sea tile has >=1 sea or shore edge")
	end

	return {
		seaTileAdjacencySource = buildSeaTileAdjacencySource(tiles),
		stats = {
			tiles = #seaNumbers,
			expected = EXPECTED_SEA_TILES,
			duplicates = duplicates,
			collisions = #collisions,
			seaEdges = seaEdgeCount,
			shoreEdges = shoreEdgeCount,
			components = #components,
			orphans = #orphans,
			seamEdges = seamEdges,
			rescueTried = rescueTried,
			rescued = rescued,
		},
	}
end

return AdjacencyGenerator
