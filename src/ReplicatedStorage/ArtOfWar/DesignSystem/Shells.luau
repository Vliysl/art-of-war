function Shells.create(name, props)
	local def = Shells.Data[name]
	if not def then
		local f = Instance.new("Frame")
		f.BackgroundColor3 = Color3.fromRGB(22, 20, 16)
		f.BorderSizePixel = 0
		if props then
			for k, v in props do
				f[k] = v
			end
		end
		return f
	end
	local img = Instance.new("ImageLabel")
	img.BackgroundTransparency = 1
	img.Image = def.Id
	img.Size = UDim2.fromScale(1, 1)
	img.BorderSizePixel = 0
	if def.Mode == "slice" then
		img.ScaleType = Enum.ScaleType.Slice
		img.SliceCenter = def.Center
		img.SliceScale = def.Scale
	elseif def.Mode == "fit" then
		img.ScaleType = Enum.ScaleType.Fit
		local r = Instance.new("UIAspectRatioConstraint")
		r.AspectRatio = def.W / def.H
		r.Parent = img
	else
		img.ScaleType = Enum.ScaleType.Stretch
	end
	if props then
		for k, v in props do
			img[k] = v
		end
	end
	return img
end

return Shells
