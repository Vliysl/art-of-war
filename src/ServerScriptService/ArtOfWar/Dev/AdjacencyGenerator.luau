--!nocheck
-- AdjacencyGenerator (DEV TOOL, run in play mode after province_id is stamped).
--
-- Produces the baked Data/ProvinceAdjacency and Data/SeaZones tables from the live
-- map geometry. NOT loaded at boot (it's a Dev module, no register()); run it via the
-- Studio MCP in a play session, capture the returned module sources, and commit them.
--
--   local gen = require(game.ServerScriptService.ArtOfWar.Dev.AdjacencyGenerator)
--   local out = gen.generate()           -- { provinceAdjacencySource, seaZonesSource, stats }
--   return out.provinceAdjacencySource .. "\n===SEAZONES===\n" .. out.seaZonesSource
--
-- Land<->land adjacency = precise mesh overlap (inflate a temp proxy clone, then
-- workspace:GetPartsInPart, real collision geometry). Sea = a wrap-aware water grid:
-- each cell center is raycast down; no province under it = open water, classified by
-- WaterBodies (named) or an "open_sea" catch-all. Orthogonally-adjacent cells give
-- shore edges (land<->zone), sea<->sea edges, the coastal flag, and zone centroids.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = workspace

local AdjacencyGenerator = {}

-- Province meshes are authored flush (CollisionFidelity=Default), so a RAW
-- GetPartsInPart on the original part returns true bordering neighbors with no
-- inflation. Only provinces that end the raw pass with 0 neighbors are retried
-- with an inflated proxy (rescue pass) to bridge hairline gaps.
local DEFAULT_RESCUE_MARGIN = 14
local DEFAULT_CELL = 48        -- water-grid cell size in studs

local function getProvincesFolder()
	local map = Workspace:FindFirstChild("ArtOfWarMap")
	return map and map:FindFirstChild("Provinces")
end

local function slug(name)
	local s = string.lower(name or "")
	s = s:gsub("[^%a%d]+", "_"):gsub("^_+", ""):gsub("_+$", "")
	if s == "" then s = "zone" end
	return s
end

-- ---- serialization (deterministic, sorted, valid Lua source) ----
local function serializeNumberArray(arr)
	table.sort(arr)
	local parts = {}
	for _, v in ipairs(arr) do parts[#parts + 1] = tostring(v) end
	return "{" .. table.concat(parts, ",") .. "}"
end

local function serializeStringArray(arr)
	table.sort(arr)
	local parts = {}
	for _, v in ipairs(arr) do parts[#parts + 1] = string.format("%q", v) end
	return "{" .. table.concat(parts, ",") .. "}"
end

local function buildProvinceAdjacencySource(provinces)
	-- provinces: sorted list of { id, land={}, coastal=bool, shore={} }
	local lines = {
		"-- BAKED true-geometric province adjacency. Generated by Dev/AdjacencyGenerator.",
		"-- Shape: [id] = { land = {ids}, coastal = bool, shore = {zoneKeys} }. DO NOT hand-edit.",
		"return {",
	}
	for _, p in ipairs(provinces) do
		lines[#lines + 1] = string.format(
			"\t[%d] = { land = %s, coastal = %s, shore = %s },",
			p.id, serializeNumberArray(p.land), tostring(p.coastal == true), serializeStringArray(p.shore))
	end
	lines[#lines + 1] = "}"
	return table.concat(lines, "\n") .. "\n"
end

local function buildSeaZonesSource(zones)
	-- zones: sorted list of { key, name, kind, x, z, seaNeighbors={}, coastalProvinces={} }
	local lines = {
		"-- BAKED sea-zone graph. Generated by Dev/AdjacencyGenerator. DO NOT hand-edit.",
		"return {",
	}
	for _, z in ipairs(zones) do
		lines[#lines + 1] = string.format(
			"\t[%q] = { name = %q, kind = %q, pos = { x = %.1f, z = %.1f }, seaNeighbors = %s, coastalProvinces = %s },",
			z.key, z.name, z.kind, z.x, z.z, serializeStringArray(z.seaNeighbors), serializeNumberArray(z.coastalProvinces))
	end
	lines[#lines + 1] = "}"
	return table.concat(lines, "\n") .. "\n"
end

-- Wait until provinces are FULLY stamped. Bootstrap stamps in waves and a
-- self-heal loop fills throttled mappings every ~6s for up to ~60s, so we only
-- treat the count as settled after it stops growing for ~15s (rides past the
-- self-heal bursts) -- not on the first transient plateau.
local function waitForStamp(folder, timeoutSec)
	local deadline = os.clock() + (timeoutSec or 90)
	local maxCount = 0
	local stablePolls = 0
	while os.clock() < deadline do
		local count = 0
		for _, part in folder:GetChildren() do
			if part:IsA("BasePart") and part:GetAttribute("province_id") then count += 1 end
		end
		if count > maxCount then
			maxCount = count
			stablePolls = 0
		else
			stablePolls += 1
		end
		if maxCount > 2000 and stablePolls >= 5 then return maxCount end
		task.wait(3)
	end
	return maxCount
end

function AdjacencyGenerator.generate(opts)
	opts = opts or {}
	local cell = opts.cellSize or DEFAULT_CELL

	local folder = getProvincesFolder()
	assert(folder, "AdjacencyGenerator: ArtOfWarMap.Provinces not found")
	local stampedCount = waitForStamp(folder, opts.stampTimeout or 90)

	-- ---- Phase 1: index stamped provinces, positions, bounds, authored coastal ----
	local partById = {}
	local authoredCoastal = {}
	local minX, maxX, minZ, maxZ = math.huge, -math.huge, math.huge, -math.huge
	for _, part in folder:GetChildren() do
		if part:IsA("BasePart") then
			local pid = part:GetAttribute("province_id")
			if pid then
				partById[pid] = part
				authoredCoastal[pid] = part:GetAttribute("coastal") == true
				local px, pz = part.Position.X, part.Position.Z
				local hx, hz = part.Size.X * 0.5, part.Size.Z * 0.5
				if px - hx < minX then minX = px - hx end
				if px + hx > maxX then maxX = px + hx end
				if pz - hz < minZ then minZ = pz - hz end
				if pz + hz > maxZ then maxZ = pz + hz end
			end
		end
	end

	-- ---- Phase 2: land<->land via mesh overlap (raw; flush meshes) ----
	local overlap = OverlapParams.new()
	overlap.FilterType = Enum.RaycastFilterType.Include
	overlap.FilterDescendantsInstances = { folder }
	overlap.MaxParts = 0

	local landSet = {}       -- [pid] = { [neighborPid] = true }
	local function addLand(a, b)
		local s = landSet[a]; if not s then s = {}; landSet[a] = s end
		s[b] = true
	end
	local function collectFrom(queryPart, pid)
		for _, hit in Workspace:GetPartsInPart(queryPart, overlap) do
			local hid = hit:GetAttribute("province_id")
			if hid and hid ~= pid then
				addLand(pid, hid)
				addLand(hid, pid)
			end
		end
	end

	-- Raw pass: flush meshes return true borderers with no inflation.
	-- (The gap-rescue runs LATER, after coastal frontage is known, so true islands
	-- aren't wrongly bridged across water.)
	for pid, part in partById do
		landSet[pid] = landSet[pid] or {}
		collectFrom(part, pid)
	end

	-- ---- Phase 3: water grid ----
	local rcParams = RaycastParams.new()
	rcParams.FilterType = Enum.RaycastFilterType.Include
	rcParams.FilterDescendantsInstances = { folder }

	local WaterBodies = require(ReplicatedStorage.ArtOfWar.Modules.WaterBodies)

	local cols = math.max(1, math.floor((maxX - minX) / cell))
	local rows = math.max(1, math.floor((maxZ - minZ) / cell))

	-- cellLand[c][r] = pid (land) ; cellZone[c][r] = zoneKey (water). nil = neither (no raycast hit but not classified)
	local cellLand = {}
	local cellZone = {}
	local zoneName = {}        -- key -> display name
	local zoneKind = {}        -- key -> kind
	local zoneCellCount = {}
	local zoneSumX, zoneSumZ = {}, {}

	local function recordZoneCell(key, name, kind, x, z)
		if not zoneName[key] then
			zoneName[key] = name
			zoneKind[key] = kind
			zoneCellCount[key] = 0
			zoneSumX[key] = 0
			zoneSumZ[key] = 0
		end
		zoneCellCount[key] += 1
		zoneSumX[key] += x
		zoneSumZ[key] += z
	end

	for c = 0, cols do
		cellLand[c] = {}
		cellZone[c] = {}
		local x = minX + c * cell + cell * 0.5
		for r = 0, rows do
			local z = minZ + r * cell + cell * 0.5
			local origin = Vector3.new(x, 2000, z)
			local res = Workspace:Raycast(origin, Vector3.new(0, -4000, 0), rcParams)
			local hit = res and res.Instance
			local hitPid = hit and hit:GetAttribute("province_id")
			if hit then
				-- Any Provinces-folder hit is LAND. A part still lacking a
				-- province_id (throttled stamp) is "unknown land": it blocks water
				-- but generates no province shore edge -- never misread as sea.
				cellLand[c][r] = hitPid or true
			else
				local name, kind = WaterBodies.getWaterBodyAt(x, z)
				local key, dispName, dispKind
				if name then
					key, dispName, dispKind = slug(name), name, string.lower(kind or "sea")
				else
					key, dispName, dispKind = "open_sea", "Open Sea", "open_sea"
				end
				cellZone[c][r] = key
				recordZoneCell(key, dispName, dispKind, x, z)
			end
		end
	end

	-- ---- Phase 4: shore (land<->zone), sea<->sea, coastal, from orthogonal cell adjacency ----
	local provinceShore = {}      -- [pid] = { [zoneKey] = true }
	local zoneProvinces = {}      -- [zoneKey] = { [pid] = true }
	local zoneNeighbors = {}      -- [zoneKey] = { [otherKey] = true }
	local function addShore(pid, key)
		local s = provinceShore[pid]; if not s then s = {}; provinceShore[pid] = s end
		s[key] = true
		local zp = zoneProvinces[key]; if not zp then zp = {}; zoneProvinces[key] = zp end
		zp[pid] = true
	end
	local function addZoneEdge(a, b)
		if a == b then return end
		local s = zoneNeighbors[a]; if not s then s = {}; zoneNeighbors[a] = s end
		s[b] = true
		local s2 = zoneNeighbors[b]; if not s2 then s2 = {}; zoneNeighbors[b] = s2 end
		s2[a] = true
	end

	local function classify(c, r)
		-- returns ("land", pid) | ("landUnknown", nil) | ("water", key) | nil
		local landVal = cellLand[c] and cellLand[c][r]
		if landVal == true then return "landUnknown", nil end
		if landVal then return "land", landVal end
		if cellZone[c] and cellZone[c][r] then return "water", cellZone[c][r] end
		return nil, nil
	end

	for c = 0, cols do
		for r = 0, rows do
			local kindA, valA = classify(c, r)
			if kindA then
				-- east neighbor with horizontal wrap (seam connects last col to col 0)
				local ec = (c == cols) and 0 or (c + 1)
				local neighborsRC = { { ec, r }, { c, math.min(r + 1, rows) } }
				for _, rc in ipairs(neighborsRC) do
					local kindB, valB = classify(rc[1], rc[2])
					if kindB then
						if kindA == "land" and kindB == "water" then
							addShore(valA, valB)
						elseif kindA == "water" and kindB == "land" then
							addShore(valB, valA)
						elseif kindA == "water" and kindB == "water" and valA ~= valB then
							addZoneEdge(valA, valB)
						end
					end
				end
			end
		end
	end

	-- ---- Phase 4.5: gap-rescue for stranded provinces ----
	-- A province that is NON-coastal AND has 0 land neighbors is unreachable. It's
	-- separated from its true neighbors by a gap wider than the raw overlap caught
	-- (never a real island -- those are coastal). Escalate an inflated proxy until a
	-- land neighbor appears. Only these few provinces get inflated, so over-connection
	-- can't reintroduce hopping for the rest of the map.
	local rescueMargins = opts.rescueMargins or { 20, 45, 90, 160 }
	local rescueTried, rescued = 0, 0
	local stillIsolated = {}
	do
		local proxyFolder = Instance.new("Folder")
		proxyFolder.Name = "__AdjGenProxies"
		proxyFolder.Parent = Workspace
		for pid, part in partById do
			local stranded = next(landSet[pid]) == nil and (provinceShore[pid] == nil or next(provinceShore[pid]) == nil)
			if stranded then
				rescueTried += 1
				for _, m in ipairs(rescueMargins) do
					local ok, clone = pcall(function() return part:Clone() end)
					if ok and clone then
						clone:ClearAllChildren()
						clone.Anchored = true
						clone.CanCollide = false
						clone.CanQuery = true
						clone.Size = part.Size + Vector3.new(m, 0, m)
						clone.CFrame = part.CFrame
						clone.Parent = proxyFolder
						collectFrom(clone, pid)
						clone:Destroy()
					end
					if next(landSet[pid]) ~= nil then break end
				end
				if next(landSet[pid]) ~= nil then rescued += 1 else stillIsolated[#stillIsolated + 1] = pid end
			end
		end
		proxyFolder:Destroy()
	end

	-- Final guarantee: no province is ever fully unreachable. Connect any province
	-- still isolated to its nearest neighbour by centroid. Logged so the map author
	-- can fix the underlying geometry; in practice these are a handful of tiny
	-- island/void provinces.
	local forced = 0
	for _, pid in ipairs(stillIsolated) do
		local pa = partById[pid].Position
		local bestId, bestD = nil, math.huge
		for otherId, otherPart in partById do
			if otherId ~= pid then
				local d = (otherPart.Position - pa).Magnitude
				if d < bestD then bestD = d; bestId = otherId end
			end
		end
		if bestId then
			addLand(pid, bestId)
			addLand(bestId, pid)
			forced += 1
		end
	end
	print(string.format("[AdjGen] gap-rescue: %d stranded, %d bridged, %d forced to nearest (ids: %s)",
		rescueTried, rescued, forced, table.concat(stillIsolated, ",")))

	-- ---- Phase 5: assemble outputs ----
	local provinces = {}
	local provIds = {}
	for pid in partById do provIds[#provIds + 1] = pid end
	table.sort(provIds)

	local histogram = {}
	local coastalCount = 0
	local islandSuspicious = {}      -- non-coastal with 0 land neighbors
	local reconAuthoredOnly, reconGeomOnly = {}, {}

	for _, pid in ipairs(provIds) do
		local land = {}
		for n in (landSet[pid] or {}) do land[#land + 1] = n end
		local shore = {}
		for key in (provinceShore[pid] or {}) do shore[#shore + 1] = key end
		local coastal = #shore > 0
		if coastal then coastalCount += 1 end

		provinces[#provinces + 1] = { id = pid, land = land, coastal = coastal, shore = shore }

		local deg = #land
		histogram[deg] = (histogram[deg] or 0) + 1
		if not coastal and deg == 0 then islandSuspicious[#islandSuspicious + 1] = pid end
		if authoredCoastal[pid] and not coastal then reconAuthoredOnly[#reconAuthoredOnly + 1] = pid end
		if coastal and not authoredCoastal[pid] then reconGeomOnly[#reconGeomOnly + 1] = pid end
	end

	local zones = {}
	local zoneKeys = {}
	for key in zoneName do zoneKeys[#zoneKeys + 1] = key end
	table.sort(zoneKeys)
	for _, key in ipairs(zoneKeys) do
		local n = {}
		for ok in (zoneNeighbors[key] or {}) do n[#n + 1] = ok end
		local cp = {}
		for pid in (zoneProvinces[key] or {}) do cp[#cp + 1] = pid end
		local count = zoneCellCount[key] or 1
		zones[#zones + 1] = {
			key = key, name = zoneName[key], kind = zoneKind[key],
			x = zoneSumX[key] / count, z = zoneSumZ[key] / count,
			seaNeighbors = n, coastalProvinces = cp,
		}
	end

	-- ---- diagnostics ----
	print(string.format("[AdjGen] stamped=%d indexed=%d  grid=%dx%d cell=%d",
		stampedCount, #provIds, cols + 1, rows + 1, cell))
	local degs = {}
	for d in histogram do degs[#degs + 1] = d end
	table.sort(degs)
	local hbits = {}
	local totalEdges = 0
	for _, d in ipairs(degs) do hbits[#hbits + 1] = string.format("%d:%d", d, histogram[d]); totalEdges += d * histogram[d] end
	print("[AdjGen] land-neighbor histogram (degree:count) -> " .. table.concat(hbits, "  "))
	print(string.format("[AdjGen] total directed land edges=%d  coastal=%d  zones=%d", totalEdges, coastalCount, #zones))
	print(string.format("[AdjGen] coastal reconcile: authored-not-geom=%d  geom-not-authored=%d  suspicious-landlocked-islands=%d",
		#reconAuthoredOnly, #reconGeomOnly, #islandSuspicious))
	if #islandSuspicious > 0 then
		local sample = {}
		for i = 1, math.min(#islandSuspicious, 20) do sample[i] = islandSuspicious[i] end
		print("[AdjGen] suspicious (non-coastal, 0 land neighbors) sample ids: " .. table.concat(sample, ", "))
	end

	return {
		provinceAdjacencySource = buildProvinceAdjacencySource(provinces),
		seaZonesSource = buildSeaZonesSource(zones),
		stats = {
			stampedCount = stampedCount, indexed = #provIds, totalEdges = totalEdges,
			coastalCount = coastalCount, zones = #zones, suspicious = #islandSuspicious,
		},
	}
end

return AdjacencyGenerator
