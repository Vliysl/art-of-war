-- BakedWorld — file-authoritative world data (the DataStore-free boot path).
--
-- When WorldConstantsServer.UseBakedWorldData is true (and this is NOT the Map Editor place),
-- DataLoader.loadBundle applies the committed baked modules in ServerData/World/ instead of
-- calling DataOverlay.applyTo, so the main game boots with ZERO world DataStore reads. The
-- baked modules are generated by `lune run tools/export-world` from the live v4 aggregates —
-- see that tool's header for the export workflow. The Data Editor is unaffected: the editor
-- place is hard-guarded out of baked mode below and keeps reading/writing its ":edit" keys.
--
-- applyTo mirrors DataOverlay.applyTo's v4 semantics exactly:
--   · provinces/countries: baked records are COMPLETE — seed tables are discarded first
--   · cultures/religions/ideologies/governmentTypes: field-level rawMerge ONTO the seed
--     modules; tombstones ({__deleted=true}, preserved by the exporter) delete seed records
--   · eu4map/tiles: never enter the bundle — ProvinceStamper pulls them via the getters
-- Reference healing is left to DataLoader.healBundle (baked files are git-reviewed, so the
-- overlay's mass-deletion breaker and per-record ref fallback are intentionally not mirrored).

local ServerScriptService = game:GetService("ServerScriptService")
local ServerStorage = game:GetService("ServerStorage")

local WorldNormalize = require(script.Parent.WorldNormalize)

local BakedWorld = {}

-- Single-module kinds and the bundle field each feeds. Provinces are paged across
-- Provinces_* modules (fixed 800-id ranges) and handled separately.
local KIND_MODULES = {
	{ module = "Countries", field = "countries" },
	{ module = "Cultures", field = "cultures" },
	{ module = "Religions", field = "religions" },
	{ module = "Ideologies", field = "ideologies" },
	{ module = "GovernmentTypes", field = "governmentTypes" },
	{ module = "EU4Map", field = "eu4Map" },
	{ module = "Tiles", field = "tiles" },
}

local activeCache = nil -- tri-state: nil = undecided, true/false = decided
local world = nil -- lazy: { ok, provinces, countries, ..., meta, failReason }
local applied = false

local function countRecords(map)
	local n = 0
	for _ in pairs(map) do
		n += 1
	end
	return n
end

-- The flag is read from WorldConstantsServer DIRECTLY (not the Bootstrap-merged shared table):
-- DataEditorService boots concurrently with Bootstrap and would otherwise race the merge.
function BakedWorld.isActive()
	if activeCache ~= nil then
		return activeCache
	end
	local flagOn = false
	local okWC, wcs = pcall(function()
		local artOfWar = ServerScriptService:FindFirstChild("ArtOfWar")
		return require(artOfWar and artOfWar:FindFirstChild("WorldConstantsServer"))
	end)
	if okWC and type(wcs) == "table" then
		flagOn = wcs.UseBakedWorldData == true
	end
	if flagOn then
		-- The Map Editor place can never enter baked mode, whatever the flag says: its whole
		-- purpose is editing the DataStore world, and baked files would mask those edits.
		local okEA, editorAdmins = pcall(function()
			local dev = ServerStorage:FindFirstChild("Dev")
			return require(dev and dev:FindFirstChild("EditorAdmins"))
		end)
		if okEA and editorAdmins and editorAdmins.isMapEditorPlace and editorAdmins.isMapEditorPlace() then
			flagOn = false
		end
	end
	activeCache = flagOn
	return activeCache
end

local function loadWorld()
	if world ~= nil then
		return world
	end
	world = { ok = false }
	local artOfWar = ServerScriptService:FindFirstChild("ArtOfWar")
	local serverData = artOfWar and artOfWar:FindFirstChild("ServerData")
	local folder = serverData and serverData:FindFirstChild("World")
	if not folder then
		world.failReason = "ServerData/World folder is missing (run `lune run tools/export-world` and Rojo-sync)"
		return world
	end
	local metaModule = folder:FindFirstChild("_meta")
	local okMeta, meta = pcall(require, metaModule)
	if not metaModule or not okMeta or type(meta) ~= "table" then
		world.failReason = "World/_meta missing or unreadable"
		return world
	end
	world.meta = meta

	-- Provinces: merge every Provinces_* page (fixed id ranges; order is irrelevant to the
	-- merged result but iterate sorted by name for deterministic behavior anyway).
	local pages = {}
	for _, child in ipairs(folder:GetChildren()) do
		if child:IsA("ModuleScript") and child.Name:match("^Provinces_") then
			table.insert(pages, child)
		end
	end
	table.sort(pages, function(a, b)
		return a.Name < b.Name
	end)
	local provinces = {}
	for _, page in ipairs(pages) do
		local okPage, records = pcall(require, page)
		if not okPage or type(records) ~= "table" then
			world.failReason = "World/" .. page.Name .. " failed to load: " .. tostring(records)
			return world
		end
		for id, rec in pairs(records) do
			provinces[id] = rec
		end
	end
	world.provinces = provinces

	for _, kind in ipairs(KIND_MODULES) do
		local child = folder:FindFirstChild(kind.module)
		if child then
			local okKind, records = pcall(require, child)
			if not okKind or type(records) ~= "table" then
				world.failReason = "World/" .. kind.module .. " failed to load: " .. tostring(records)
				return world
			end
			world[kind.field] = records
		else
			world[kind.field] = {}
		end
	end

	if countRecords(world.provinces) == 0 or countRecords(world.countries) == 0 then
		world.failReason = "baked provinces/countries are empty — refusing baked mode"
		return world
	end
	world.ok = true
	return world
end

function BakedWorld.isAvailable()
	local w = loadWorld()
	if not w.ok and w.failReason and not w.warned then
		w.warned = true
		warn("[BakedWorld] unavailable: " .. w.failReason)
	end
	return w.ok
end

-- Merge kinds where the baked aggregate is an OVERLAY on the seed modules (not a complete
-- snapshot) — tombstones here must delete seed records, mirroring DataOverlay.applyTo.
local MERGE_KINDS = {
	{ field = "cultures" },
	{ field = "religions" },
	{ field = "ideologies" },
	{ field = "governmentTypes" },
}

function BakedWorld.applyTo(bundle)
	local w = loadWorld()
	if not w.ok then
		error("[BakedWorld] applyTo called while unavailable: " .. tostring(w.failReason))
	end

	-- v4: baked provinces/countries are authoritative and complete — discard the seeds.
	bundle.provinces = {}
	bundle.countries = {}

	for tag, rec in pairs(w.countries) do
		if not WorldNormalize.isTombstone(rec) then
			bundle.countries[tag] = rec
		end
	end
	for _, kind in ipairs(MERGE_KINDS) do
		local target = bundle[kind.field]
		if target then
			for id, rec in pairs(w[kind.field]) do
				if WorldNormalize.isTombstone(rec) then
					target[id] = nil
				else
					target[id] = WorldNormalize.rawMerge(target[id], rec)
				end
			end
		end
	end
	for id, rec in pairs(w.provinces) do
		if not WorldNormalize.isTombstone(rec) then
			-- Records are baked fully normalized; re-normalizing is an idempotent safety
			-- net against a stale export from before a defaulting-rule change.
			bundle.provinces[id] = WorldNormalize.normalizeProvince(rec)
		end
	end

	applied = true
	print(
		string.format(
			"[BakedWorld] applied baked world (%d provinces, %d countries, schema %s, exported %s)",
			countRecords(bundle.provinces),
			countRecords(bundle.countries),
			tostring(w.meta and w.meta.schemaVersion),
			tostring(w.meta and w.meta.exportedAtIso or w.meta and w.meta.exportedAt)
		)
	)
	return bundle
end

function BakedWorld.wasApplied()
	return applied
end

-- Same surface DataOverlay exposes to ProvinceStamper, sourced from the baked files.
function BakedWorld.getEU4MapOverrides()
	local w = loadWorld()
	if not w.ok then
		return {}
	end
	local out = {}
	for k, v in pairs(w.eu4Map) do
		if not WorldNormalize.isTombstone(v) then
			out[k] = v
		end
	end
	return out
end

function BakedWorld.getTileOverrides()
	local w = loadWorld()
	if not w.ok then
		return {}
	end
	local out = {}
	for k, v in pairs(w.tiles) do
		if not WorldNormalize.isTombstone(v) then
			out[k] = v
		end
	end
	return out
end

function BakedWorld.isCollapsed()
	local w = loadWorld()
	local schema = w.meta and w.meta.schemaVersion
	return schema == "v3" or schema == "v4"
end

function BakedWorld.meta()
	local w = loadWorld()
	return w.meta
end

return BakedWorld
