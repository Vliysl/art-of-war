local function province(id, data)
	data.id = id
	data.cores = data.cores or { data.ownerTag }
	data.defaultCores = data.defaultCores or table.clone(data.cores) -- homeland cores (static); default = seed cores
	data.controllerTag = data.controllerTag or data.ownerTag
	data.isCity = data.isCity or false
	data.centerOfTrade = data.centerOfTrade or 0
	data.devTier = data.devTier or 1
	data.infraTier = data.infraTier or 1
	data.fortTier = data.fortTier or 0
	data.unrest = data.unrest or 0
	data.autonomy = data.autonomy or 0
	data.climate = data.climate or "temperate"
	data.districts = data.districts or {} -- economy rework: slot-indexed districts (index == slot; nil == empty)
	data.claims = data.claims or {} -- nations with a claim on this province (editor-painted; parallels cores)
	return data
end
